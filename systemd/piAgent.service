[Unit]
Description=Home Control Pi Agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=homecontrol
Group=homecontrol
WorkingDirectory=/opt/homeControl
ExecStart=/opt/homeControl/.venv/bin/python /opt/homeControl/src/piAgent.py
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
